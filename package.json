{
  "name": "clawd-office",
  "version": "0.2.0",
  "description": "Pixel-art virtual office for AI agent teams — live presence, room navigation, agent CRUD, and task assignment in a retro-styled shared workspace.",
  "type": "module",
  "license": "MIT",
  "author": "Florian Wartner <florian@wartner.io> (https://pixelandprocess.de)",
  "scripts": {
    "setup": "node setup.mjs",
    "setup:force": "node setup.mjs --force",
    "setup:auto": "node setup.mjs --yes",
    "postinstall": "node setup.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "serve": "node server.mjs",
    "serve:build": "tsc -b && vite build && node server.mjs",
    "start": "npm run serve:build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^29.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.0"
  }
}
