{
  "name": "agent-office",
  "version": "0.3.0",
  "description": "Pixel-art virtual office for AI agent teams — live presence, room navigation, agent CRUD, and task assignment in a retro-styled shared workspace.",
  "type": "module",
  "license": "MIT",
  "author": "Florian Wartner <florian@wartner.io> (https://pixelandprocess.de)",
  "scripts": {
    "setup": "node setup.mjs",
    "setup:force": "node setup.mjs --force",
    "setup:auto": "node setup.mjs --yes",
    "postinstall": "node setup.mjs",
    "dev": "npm run build:server && vite",
    "build:server": "tsup src/server/index.ts src/db/index.ts src/db/migrate.ts src/db/seed.ts src/bot/index.ts --format esm --out-dir dist-server --external better-sqlite3 --external pg --external grammy --external @grammyjs/conversations",
    "build": "npm run build:server && tsc -b && vite build",
    "preview": "vite preview",
    "serve": "node server.mjs",
    "serve:build": "npm run build && node server.mjs",
    "start": "npm run serve:build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.1.1",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "grammy": "^1.41.1",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.18.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^3.2.4"
  }
}
